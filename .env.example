# Database
DATABASE_URL=postgresql://moment:moment@localhost:5432/moment
DIRECT_URL=postgresql://moment:moment@localhost:5432/moment

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-strong-secret
EMAIL_SERVER_HOST=localhost
EMAIL_SERVER_PORT=1025
EMAIL_SERVER_USER=""
EMAIL_SERVER_PASSWORD=""
