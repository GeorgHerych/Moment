S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=moment-local
S3_FORCE_PATH_STYLE=true

# Redis / Queues
REDIS_URL=redis://localhost:6379

# Stripe (stub)
